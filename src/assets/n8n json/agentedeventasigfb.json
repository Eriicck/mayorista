    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\n\nconst userId = $('Preparar Datos Meta').first().json.senderId;\nconst mensajeNuevo = $json.mensajeProcesado;\nconst tiempoActual = new Date().getTime();\n\nif (staticData[userId] === undefined) {\n  staticData[userId] = { texto: \"\", ultimoTiempo: 0 };\n}\n\nstaticData[userId].texto = staticData[userId].texto + mensajeNuevo + \". \";\nstaticData[userId].ultimoTiempo = tiempoActual;\n\nreturn {\n  userId: userId,\n  miTiempo: tiempoActual\n};"
      },
      "id": "anotar-mensajes-ig",
      "name": "Anotar Mensajes",
