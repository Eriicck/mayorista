      "webhookId": "9c1b359f-c67b-402f-b40b-741ef11329bb"
    },
    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst userId = $json.userId;\nconst tiempoNodoAnterior = $json.miTiempo;\n\nif (staticData[userId].ultimoTiempo === tiempoNodoAnterior) {\n    const mensajeFinal = staticData[userId].texto;\n    staticData[userId] = undefined;\n    return {\n        continuar: true,\n        mensajeAgrupado: mensajeFinal,\n        userId: userId\n    };\n} else {\n    return { continuar: false };\n}"
      },
