    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const staticData = $getWorkflowStaticData('global');\n\n// Leemos los datos procesados\nconst telefono = $json.sessionId || $('WhatsApp Trigger').first().json.messages[0].from;\nconst mensajeNuevo = $json.mensajeProcesado;\nconst tiempoActual = new Date().getTime();\n\n// Si es el primer mensaje, preparamos una caja de texto vacía\nif (staticData[telefono] === undefined) {\n  staticData[telefono] = { texto: \"\", ultimoTiempo: 0 };\n}\n\n// Juntamos el texto (sea tipeado o dictado por voz)\nstaticData[telefono].texto = staticData[telefono].texto + mensajeNuevo + \". \";\nstaticData[telefono].ultimoTiempo = tiempoActual;\n\nreturn {\n  telefono: telefono,\n  miTiempo: tiempoActual\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [560, -440],
      "id": "c5f047ad-d8e8-4c9f-bbce-3233ac3607eb",
      "name": "Anotar Mensajes"
    },
