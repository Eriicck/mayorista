      "typeVersion": 1.1,
      "position": [760, -440],
      "id": "e2c51222-f113-46f6-a4c6-c2e67e0f7063",
      "name": "La Sala de Espera",
      "webhookId": "48c6d885-3928-410b-a55d-a0d523121fe9"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst telefono = $json.telefono;\nconst miTiempo = $json.miTiempo;\n\n// Si nadie más escribió en estos 5 segundos...\nif (staticData[telefono].ultimoTiempo === miTiempo) {\n  const mensajeFinal = staticData[telefono].texto;\n  \n  // Vaciamos la caja de texto\n  staticData[telefono] = { texto: \"\", ultimoTiempo: 0 };\n\n  return {\n    continuar: true,\n    mensajeAgrupado: mensajeFinal,\n    sessionId: telefono\n  };\n} else {\n  // Alguien escribió después, así que esta ejecución muere en silencio aquí\n  return {\n    continuar: false\n  };\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [960, -440],
      "id": "9df40124-782e-478f-8331-7b129e21e5fb",
